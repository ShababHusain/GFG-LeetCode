class Solution {
    public int countPartitions(int[] arr, int diff) {
        int n = arr.length;
        int total = 0;
        for (int v : arr) total += v;

        // If (total + diff) is odd or target negative, no solution
        if ((total + diff) % 2 != 0) return 0;
        int target = (total + diff) / 2;
        if (target < 0) return 0;

        // Separate zeros because each zero doubles the number of ways
        int zeros = 0;
        ArrayList<Integer> nums = new ArrayList<>();
        for (int v : arr) {
            if (v == 0) zeros++;
            else nums.add(v);
        }

        long[] dp = new long[target + 1];
        dp[0] = 1L;
        for (int v : nums) {
            if (v > target) continue;
            for (int s = target; s >= v; s--) {
                dp[s] += dp[s - v];
            }
        }

        long ways = dp[target];
        if (zeros > 0) {
            ways = ways * (1L << zeros);
        }

        // Return as int per signature (counts fit in long; cast to int)
        return (int) ways;
    }
}
