class Solution {
    public ArrayList<ArrayList<Integer>> verticalOrder(Node root) {
        ArrayList<ArrayList<Integer>> result = new ArrayList<>();
        if (root == null) return result;

        HashMap<Integer, ArrayList<Integer>> map = new HashMap<>();
        Queue<Node> nodeQ = new LinkedList<>();
        Queue<Integer> hdQ = new LinkedList<>();

        nodeQ.add(root);
        hdQ.add(0);

        int minHd = 0, maxHd = 0;

        while (!nodeQ.isEmpty()) {
            Node node = nodeQ.poll();
            int hd = hdQ.poll();

            map.computeIfAbsent(hd, k -> new ArrayList<>()).add(node.data);

            if (node.left != null) {
                nodeQ.add(node.left);
                hdQ.add(hd - 1);
                if (hd - 1 < minHd) minHd = hd - 1;
            }
            if (node.right != null) {
                nodeQ.add(node.right);
                hdQ.add(hd + 1);
                if (hd + 1 > maxHd) maxHd = hd + 1;
            }
        }

        for (int h = minHd; h <= maxHd; h++) {
            ArrayList<Integer> list = map.get(h);
            if (list == null) list = new ArrayList<>();
            result.add(list);
        }

        return result;
    }
}
