class Solution {
    public int mirrorDistance(int n) {
        int rev = reverseInt(n);
        return Math.abs(n - rev);
    }

    private int reverseInt(int x) {
        int r = 0;
        while (x > 0) {
            r = r * 10 + (x % 10);
            x /= 10;
        }
        return r;
    }
}
