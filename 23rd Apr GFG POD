class Solution {
    public boolean canSplit(int arr[]) {
        int n = arr.length;
        if (n < 2) return false; // need two non-empty parts

        long total = 0;
        for (int v : arr) total += v;

        long prefix = 0;
        // try split after index i (left: 0..i, right: i+1..n-1)
        for (int i = 0; i < n - 1; i++) {
            prefix += arr[i];
            if (prefix == total - prefix) return true;
        }
        return false;
    }
}
