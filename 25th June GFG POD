class Solution {
    public static ArrayList<Integer> increasingNumbers(int n) {
        ArrayList<Integer> result = new ArrayList<>();
        
        // n == 1 -> 0..9
        if (n == 1) {
            for (int i = 0; i <= 9; i++) result.add(i);
            return result;
        }
        
        // impossible if n > 10
        if (n > 10) return result;
        
        // For n > 1, first digit cannot be 0.
        backtrack(result, new ArrayList<>(), n, 1);
        return result;
    }
    
    private static void backtrack(ArrayList<Integer> result, ArrayList<Integer> current, int n, int start) {
        if (current.size() == n) {
            int num = 0;
            for (int d : current) num = num * 10 + d;
            result.add(num);
            return;
        }
        
        // Prune: if remaining digits available are fewer than needed, stop.
        // digits left = 9 - start + 1  (since start..9 inclusive)
        // needed = n - current.size()
        for (int digit = start; digit <= 9; digit++) {
            int remainingDigitsAvailable = 9 - digit + 1;
            int needed = n - current.size();
            if (remainingDigitsAvailable < needed) break; // cannot fill length n starting from this digit
            
            current.add(digit);
            backtrack(result, current, n, digit + 1);
            current.remove(current.size() - 1);
        }
    }
}
