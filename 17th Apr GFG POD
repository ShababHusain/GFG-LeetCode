class Solution {
    public boolean canFormPalindrome(String s) {
        if (s == null || s.length() == 0) return true;
        int[] freq = new int[26];
        for (int i = 0; i < s.length(); i++) {
            freq[s.charAt(i) - 'a']++;
        }
        int oddCount = 0;
        for (int c : freq) {
            if ((c & 1) == 1) oddCount++;
            if (oddCount > 1) return false;
        }
        return true;
    }
}
