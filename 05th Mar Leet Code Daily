class Solution {
    public int minOperations(String s) {
        int costA = 0; // cost to make s = 010101...
        int costB = 0; // cost to make s = 101010...
        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);
            char expectA = (i % 2 == 0) ? '0' : '1';
            char expectB = (i % 2 == 0) ? '1' : '0';
            if (ch != expectA) costA++;
            if (ch != expectB) costB++;
        }
        return Math.min(costA, costB);
    }
}
