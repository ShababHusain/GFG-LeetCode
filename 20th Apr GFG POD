class Solution {
    public int derangeCount(int n) {
        if (n == 0) return 1; // optional, safe
        if (n == 1) return 0;
        int d0 = 1; // D(0)
        int d1 = 0; // D(1)
        for (int i = 2; i <= n; i++) {
            int di = (i - 1) * (d1 + d0);
            d0 = d1;
            d1 = di;
        }
        return d1;
    }
}
