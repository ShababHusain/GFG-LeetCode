class Solution {
    public ArrayList<Integer> freqInRange(int[] arr, int[][] queries) {
        // Map value -> sorted list of indices where it appears
        Map<Integer, ArrayList<Integer>> pos = new HashMap<>();
        for (int i = 0; i < arr.length; i++) {
            pos.computeIfAbsent(arr[i], k -> new ArrayList<>()).add(i);
        }

        ArrayList<Integer> ans = new ArrayList<>(queries.length);
        for (int[] q : queries) {
            int l = q[0], r = q[1], x = q[2];
            ArrayList<Integer> list = pos.get(x);
            if (list == null) {
                ans.add(0);
                continue;
            }
            int leftIdx = lowerBound(list, l);   // first index >= l
            int rightIdx = upperBound(list, r);  // first index > r
            ans.add(rightIdx - leftIdx);
        }
        return ans;
    }

    // first position in list with value >= target
    private int lowerBound(ArrayList<Integer> list, int target) {
        int lo = 0, hi = list.size(); // hi is exclusive
        while (lo < hi) {
            int mid = lo + (hi - lo) / 2;
            if (list.get(mid) >= target) hi = mid;
            else lo = mid + 1;
        }
        return lo;
    }

    // first position in list with value > target
    private int upperBound(ArrayList<Integer> list, int target) {
        int lo = 0, hi = list.size();
        while (lo < hi) {
            int mid = lo + (hi - lo) / 2;
            if (list.get(mid) > target) hi = mid;
            else lo = mid + 1;
        }
        return lo;
    }
}
