class Solution {
    public int countSubarrays(int[] arr) {
        int n = arr.length;
        int[] nextSmaller = new int[n];
        Arrays.fill(nextSmaller, n); // default: no smaller element to the right

        Deque<Integer> stack = new ArrayDeque<>(); // store indices, values non-decreasing

        for (int i = 0; i < n; i++) {
            while (!stack.isEmpty() && arr[i] < arr[stack.peek()]) {
                nextSmaller[stack.pop()] = i;
            }
            stack.push(i);
        }

        long ans = 0L;
        for (int i = 0; i < n; i++) {
            ans += (nextSmaller[i] - i);
        }
        return (int) ans;
    }

}
