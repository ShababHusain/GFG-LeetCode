class Solution {
    public int closestTarget(String[] words, String target, int startIndex) {
        int n = words.length;
        for (int d = 0; d < n; d++) {
            int right = (startIndex + d) % n;
            if (words[right].equals(target)) return d;
            int left = (startIndex - d) % n;
            if (left < 0) left += n;
            if (words[left].equals(target)) return d;
        }
        return -1;
    }
}
