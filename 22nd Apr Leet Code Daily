class Solution {
    public List<String> twoEditWords(String[] queries, String[] dictionary) {
        List<String> ans = new ArrayList<>();
        for (String q : queries) {
            if (matchesWithinTwo(q, dictionary)) {
                ans.add(q);
            }
        }
        return ans;
    }

    private boolean matchesWithinTwo(String q, String[] dict) {
        for (String w : dict) {
            if (withinTwoEdits(q, w)) return true;
        }
        return false;
    }

    private boolean withinTwoEdits(String a, String b) {
        int mismatches = 0;
        for (int i = 0; i < a.length(); i++) {
            if (a.charAt(i) != b.charAt(i)) {
                mismatches++;
                if (mismatches > 2) return false; // early exit
            }
        }
        return true;
    }
}
