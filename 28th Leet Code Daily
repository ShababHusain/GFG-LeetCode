class Solution {
    public int concatenatedBinary(int n) {
        final int MOD = 1_000_000_007;
        long ans = 0;
        int bits = 0;          // current bit length for i

        for (int i = 1; i <= n; ++i) {
            // increase bit length when i is a power of two
            if ((i & (i - 1)) == 0) bits++;
            ans = ((ans << bits) % MOD + i) % MOD;
        }
        return (int) ans;
    }

}
