class Solution {
    public ArrayList<String> generateIp(String s) {
        ArrayList<String> result = new ArrayList<>();
        if (s == null) return result;
        int n = s.length();
        if (n < 4 || n > 12) return result; // quick pruning

        backtrack(s, 0, new ArrayList<>(), result);
        return result;
    }

    private void backtrack(String s, int start, ArrayList<String> parts, ArrayList<String> result) {
        // If we have 4 parts, check if we've consumed the whole string
        if (parts.size() == 4) {
            if (start == s.length()) {
                result.add(String.join(".", parts));
            }
            return;
        }

        // Try segments of length 1 to 3
        for (int len = 1; len <= 3; len++) {
            if (start + len > s.length()) break;

            String seg = s.substring(start, start + len);

            // Leading zero check: "0" is allowed, but "01", "00", etc. are not
            if (seg.length() > 1 && seg.charAt(0) == '0') continue;

            // Numeric range check
            int val = Integer.parseInt(seg);
            if (val > 255) continue;

            parts.add(seg);
            backtrack(s, start + len, parts, result);
            parts.remove(parts.size() - 1);
        }
    }
}
