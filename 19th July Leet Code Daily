class Solution {
    public String smallestSubsequence(String s) {
        int n = s.length();
        // last occurrence index for each character
        int[] last = new int[26];
        for (int i = 0; i < n; ++i) last[s.charAt(i) - 'a'] = i;

        boolean[] inStack = new boolean[26];
        StringBuilder stack = new StringBuilder();

        for (int i = 0; i < n; ++i) {
            char ch = s.charAt(i);
            int idx = ch - 'a';
            if (inStack[idx]) continue; // already included

            // pop while top > ch and top appears later again
            while (stack.length() > 0) {
                char top = stack.charAt(stack.length() - 1);
                int topIdx = top - 'a';
                if (top > ch && last[topIdx] > i) {
                    // remove top
                    stack.deleteCharAt(stack.length() - 1);
                    inStack[topIdx] = false;
                } else break;
            }

            stack.append(ch);
            inStack[idx] = true;
        }

        return stack.toString();
    }
}
