class Solution {
    static ArrayList<Integer> diagView(int mat[][]) {
        int n = mat.length;
        ArrayList<Integer> res = new ArrayList<>(n * n);
        // s = i + j ranges from 0 to 2*(n-1)
        for (int s = 0; s <= 2 * (n - 1); s++) {
            for (int i = 0; i < n; i++) {
                int j = s - i;
                if (j >= 0 && j < n) {
                    res.add(mat[i][j]);
                }
            }
        }
        return res;
    }
}
