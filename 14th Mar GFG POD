class Solution {
    public ArrayList<Integer> topView(Node root) {
        ArrayList<Integer> result = new ArrayList<>();
        if (root == null) return result;

        // TreeMap keeps horizontal distances sorted from leftmost to rightmost
        TreeMap<Integer, Integer> hdToValue = new TreeMap<>();

        // Queue of pairs: node and its horizontal distance
        Queue<Node> nodeQ = new LinkedList<>();
        Queue<Integer> hdQ = new LinkedList<>();

        nodeQ.add(root);
        hdQ.add(0);

        while (!nodeQ.isEmpty()) {
            Node node = nodeQ.poll();
            int hd = hdQ.poll();

            // Record the first node seen at this horizontal distance
            if (!hdToValue.containsKey(hd)) {
                hdToValue.put(hd, node.data);
            }

            if (node.left != null) {
                nodeQ.add(node.left);
                hdQ.add(hd - 1);
            }
            if (node.right != null) {
                nodeQ.add(node.right);
                hdQ.add(hd + 1);
            }
        }

        // Collect values from leftmost hd to rightmost hd
        for (int val : hdToValue.values()) {
            result.add(val);
        }
        return result;
    }
}
