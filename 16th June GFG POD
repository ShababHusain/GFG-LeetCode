import java.util.*;

class Solution {
    public ArrayList<Integer> constructList(int[][] queries) {
        ArrayList<Integer> arr = new ArrayList<>();
        arr.add(0); // initial value
        int mask = 0;

        for (int[] query : queries) {
            int type = query[0], x = query[1];
            if (type == 0) {
                // Insert adjusted value
                arr.add(x ^ mask);
            } else {
                // Update global mask
                mask ^= x;
            }
        }

        // Apply final mask to all elements
        ArrayList<Integer> result = new ArrayList<>();
        for (int val : arr) {
            result.add(val ^ mask);
        }

        Collections.sort(result);
        return result;
    }
}
