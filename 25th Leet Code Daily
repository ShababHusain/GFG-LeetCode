class Solution {
    public int[] sortByBits(int[] arr) {
        // Convert to Integer[] to use a custom comparator easily
        Integer[] a = new Integer[arr.length];
        for (int i = 0; i < arr.length; i++) a[i] = arr[i];

        Arrays.sort(a, new Comparator<Integer>() {
            @Override
            public int compare(Integer x, Integer y) {
                int bx = Integer.bitCount(x);
                int by = Integer.bitCount(y);
                if (bx != by) return bx - by;      // primary: number of 1 bits
                return x - y;                      // secondary: numeric value
            }
        });

        // Copy back to int[]
        for (int i = 0; i < arr.length; i++) arr[i] = a[i];
        return arr;
    }

    // concise lambda version (Java 8+)
    public int[] sortByBitsLambda(int[] arr) {
        Integer[] a = Arrays.stream(arr).boxed().toArray(Integer[]::new);
        Arrays.sort(a, (x, y) -> {
            int bx = Integer.bitCount(x);
            int by = Integer.bitCount(y);
            return (bx != by) ? bx - by : x - y;
        });
        for (int i = 0; i < arr.length; i++) arr[i] = a[i];
        return arr;
    }
}
