class Solution {
    public boolean check(int[] nums) {
        int n = nums.length;
        if (n <= 1) return true;

        int drops = 0;
        for (int i = 0; i < n; i++) {
            int j = (i + 1) % n;
            if (nums[i] > nums[j]) drops++;
            if (drops > 1) return false; // early exit
        }
        return true;
    }
}
