class Solution {
    public int coin(int[] arr) {
        if (arr == null || arr.length == 0) return 0; // handle empty input defensively
        int left = 0, right = arr.length - 1;
        while (left < right) {
            if (arr[left] >= arr[right]) {
                left++;   // pick left end
            } else {
                right--;  // pick right end
            }
        }
        return arr[left];
    }
}
