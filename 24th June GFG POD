import java.util.ArrayList;

class Solution {
    public ArrayList<ArrayList<Integer>> shortestDist(int[][] mat) {
        int n = mat.length;
        int[][] ans = new int[n][n];
        
        // This array ensures we don't explore paths from a cell that we already know leads to a dead end.
        boolean[][] failed = new boolean[n][n];
        
        ArrayList<ArrayList<Integer>> result = new ArrayList<>();

        // Start DFS from (0, 0)
        if (dfs(0, 0, mat, ans, failed, n)) {
            // Convert the primitive 2D array into an ArrayList of ArrayLists
            for (int i = 0; i < n; i++) {
                ArrayList<Integer> row = new ArrayList<>();
                for (int j = 0; j < n; j++) {
                    row.add(ans[i][j]);
                }
                result.add(row);
            }
        } else {
            // If no path is found, return [[-1]]
            ArrayList<Integer> failedRow = new ArrayList<>();
            failedRow.add(-1);
            result.add(failedRow);
        }
        
        return result;
    }
    
    private boolean dfs(int r, int c, int[][] mat, int[][] ans, boolean[][] failed, int n) {
        // Base Case 1: Reached the destination successfully
        if (r == n - 1 && c == n - 1) {
            ans[r][c] = 1;
            return true;
        }

        // Base Case 2: Out of bounds, blocked cell, or already proven to be a dead-end
        if (r >= n || c >= n || mat[r][c] == 0 || failed[r][c]) {
            return false;
        }

        // Mark the current cell as part of the tentative path
        ans[r][c] = 1;
        int maxJump = mat[r][c];

        // Explore jumps incrementally to satisfy "shortest possible jumps first"
        for (int step = 1; step <= maxJump; step++) {
            // 1st Priority: Move Right
            if (c + step < n && dfs(r, c + step, mat, ans, failed, n)) {
                return true;
            }
            
            // 2nd Priority: Move Down
            if (r + step < n && dfs(r + step, c, mat, ans, failed, n)) {
                return true;
            }
        }

        // Backtrack: No valid path found from this cell
        ans[r][c] = 0;
        failed[r][c] = true; // Memoize the failure to avoid redundant checks
        return false;
    }
}
