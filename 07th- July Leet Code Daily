class Solution {
    public long sumAndMultiply(int n) {
        String s = String.valueOf(n);
        long x = 0L;
        long sum = 0L;
        for (int i = 0; i < s.length(); i++) {
            char c = s.charAt(i);
            if (c == '0') continue;
            int d = c - '0';
            x = x * 10 + d;
            sum += d;
        }
        return x * sum;
    }
}
