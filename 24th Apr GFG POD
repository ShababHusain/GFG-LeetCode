class Solution {
    public int visibleBuildings(int arr[]) {
        if (arr == null || arr.length == 0) return 0;
        int count = 0;
        int maxSoFar = Integer.MIN_VALUE;
        for (int h : arr) {
            if (h >= maxSoFar) {
                count++;
                maxSoFar = h;
            }
        }
        return count;
    }
}
