class Solution {
    public int sumDiffPairs(int[] arr, int k) {
        if (arr == null || arr.length < 2) return 0;
        Arrays.sort(arr);
        int i = arr.length - 1;
        long sum = 0L;
        while (i > 0) {
            if (arr[i] - arr[i - 1] < k) {
                sum += (long)arr[i] + (long)arr[i - 1];
                i -= 2;
            } else {
                i -= 1;
            }
        }
        return (int) sum;
    }
}
